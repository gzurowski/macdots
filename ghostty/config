#
# Ghostty configuration
#
# For an overview of options, see: https://ghostty.org/docs/config/reference
#

# Color theme
# Use VSCode's Default Light+ terminal color palette
palette = 0=#000000
palette = 1=#cd3131
palette = 2=#107c10
palette = 3=#949800
palette = 4=#0451a5
palette = 5=#bc05bc
palette = 6=#0598bc
palette = 7=#555555
palette = 8=#666666
palette = 9=#cd3131
palette = 10=#14ce14
palette = 11=#b5ba00
palette = 12=#0451a5
palette = 13=#bc05bc
palette = 14=#0598bc
palette = 15=#a5a5a5
background = #ffffff
foreground = #000000

# Non-blinking box cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Enable copy-on-select
# Must be explicitly enabled on macOS.
# See: https://ghostty.org/docs/config/reference#copy-on-select
copy-on-select = clipboard

# Quick Terminal
# See: https://ghostty.org/docs/config/keybind/reference#toggle_quick_terminal
keybind = global:cmd+shift+grave_accent=toggle_quick_terminal
quick-terminal-position = center

# Delete whole line with CMD+Delete
# See: https://github.com/ghostty-org/ghostty/issues/3646
keybind = cmd+backspace=esc:w

window-padding-x = 5
window-padding-y = 5